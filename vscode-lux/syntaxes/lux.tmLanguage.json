{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Lux",
  "scopeName": "source.lux",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.lux",
          "begin": "--\\[\\[",
          "end": "\\]\\]"
        },
        {
          "name": "comment.line.double-dash.lux",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.lux",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.lux", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.lux",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.lux", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.other.multiline.lux",
          "begin": "\\[\\[",
          "end": "\\]\\]"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.lux",
          "match": "\\b0[xX][0-9a-fA-F]+(?:\\.[0-9a-fA-F]+)?(?:[pP][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.float.lux",
          "match": "\\b[0-9]+\\.[0-9]+(?:[eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.lux",
          "match": "\\b[0-9]+(?:[eE][+-]?[0-9]+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.lux",
          "match": "\\b(if|then|else|elseif|end|for|in|while|do|repeat|until|break|return|goto)\\b"
        },
        {
          "name": "keyword.other.lux",
          "match": "\\b(local|function|and|or|not|as|declare|export|from|import|module|enum|async|await|mut|class|new|interface|extends|implements)\\b"
        },
        {
          "name": "constant.language.lux",
          "match": "\\b(true|false|nil)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.lux",
          "match": "\\+|-|\\*|/|%|\\^|#|==|~=|!=|\\|\\||&&|!|<=|>=|<|>|=|\\.\\.|\\.\\.\\."
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.lux",
          "match": ":\\s*([a-zA-Z_]\\w*)",
          "captures": {
            "1": { "name": "entity.name.type.lux" }
          }
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.lux",
          "match": "\\b(function)\\s+([a-zA-Z_][\\w.:]*)",
          "captures": {
            "1": { "name": "keyword.other.lux" },
            "2": { "name": "entity.name.function.lux" }
          }
        },
        {
          "name": "meta.function-call.lux",
          "match": "\\b([a-zA-Z_]\\w*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.lux" }
          }
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.language.self.lux",
          "match": "\\bself\\b"
        }
      ]
    }
  }
}
