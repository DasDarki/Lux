{
  "name": "lux-lang",
  "displayName": "Lux Language",
  "description": "Language support for the Lux typed Lua transpiler",
  "version": "0.1.0",
  "publisher": "DasDarki",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:lux"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "lux",
        "aliases": [
          "Lux",
          "lux"
        ],
        "extensions": [
          ".lux"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "lux",
        "aliases": [
          "Lux Declaration"
        ],
        "extensions": [
          ".d.sel"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lux",
        "scopeName": "source.lux",
        "path": "./syntaxes/lux.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Lux",
      "properties": {
        "lux.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Lux compiler executable. If empty, 'lux' must be on PATH."
        },
        "lux.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication between VS Code and the Lux language server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  }
}
