-- Test: Pre/Post Increment and Decrement
local x: number = 10

x++
print(x)  -- 11

x~~
print(x)  -- 10

-- As expression: post-increment returns old value
local a = x++
print(a, x)  -- 10, 11

-- Pre-increment returns new value
local b = ++x
print(b, x)  -- 12, 12

-- Pre-decrement returns new value
local c = ~~x
print(c, x)  -- 11, 11

-- Post-decrement returns old value
local d = x~~
print(d, x)  -- 11, 10

-- On table fields
local obj = { count = 0 }
obj.count++
print(obj.count)  -- 1

local old = obj.count++
print(old, obj.count)  -- 1, 2

-- On array elements
local arr: number[] = {10, 20, 30}
arr[1]++
print(arr[1])  -- 11

local prev = arr[1]++
print(prev, arr[1])  -- 11, 12
