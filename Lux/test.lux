export function add(a: number, b: number): number
    return a + b
end

local result = add(1, 2)
print("Result: " .. result)

local arr = {10, 20, 30}
local sum = 0
for i = 0, 2 do
    sum = sum + arr[i]
end
print(sum)

export function greet(name: string, greeting: string)
    return greeting + ", " .. name + "!"
end

local msg = greet("World", "Hello")
print(msg)

local len = #arr
print(len)

local strInterp = `The sum of 1 and 2 is {result}`
print(strInterp)

local nilTest: string? = nil
greet(nilTest ?? "test", "Hi")

export enum Color
    Red
    Green
    Blue
end

enum Direction
    North = 0
    South = 1
    East = 2
    West = 3
end

local c: Color = Color.Red
local d: Direction = Direction.North
print(c)
print(d)

function testEnum1(t: Color)
    print("Color: " .. t)
end

function testEnum2(t: number)
    print("Test 2: " .. t)
end

testEnum1(Color.Green)
testEnum2(Direction.South)

for key, value in pairs(Color) do
    print(key, value)
end

local something: any = 42
if something is number then
    print("It's a number: " .. (something + 1))
end

if something is string then
    print("It's a string")
end

local n = something as number
print(n + 1)

local maybeColor: any = Color.Red
if maybeColor is Color then
    print("Got a color")
end

local u: number | string = 42
if u is number then
    print("then-num: " .. (u + 1))
else
    print("else-str: " .. u)
end

local v: number | string = "hi"
if not (v is number) then
    print("not-num-str: " .. v)
else
    print("not-num-num: " .. (v + 1))
end

local a: any = 1
local b: any = "x"
if (a is number) and (b is string) then
    print("compound: " .. (a + 1) .. b)
end